# ═══════════════════════════════════════════════════════════
#  NVIDIA Strategic Intelligence Agent
#  Environment Configuration Template
#
#  HOW TO USE:
#    1. Copy this file:  cp .env.example .env
#    2. Fill in your values below
#    3. NEVER commit .env to Git (it is in .gitignore)
# ═══════════════════════════════════════════════════════════

# ── LLM Backend selection ─────────────────────────────────
# Choose ONE of: groq | ollama | huggingface
LLM_BACKEND=groq

# ── Option A: Groq (RECOMMENDED — free cloud, ~0.5s/call) ─
# Sign up at: https://console.groq.com (no credit card)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── Option B: Ollama (fully local, no internet required) ──
# Install: https://ollama.com
# Then run: ollama pull qwen3:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b

# ── Option C: HuggingFace Inference API (free, slower) ────
# Token at: https://huggingface.co/settings/tokens
HF_API_KEY=your_huggingface_token_here
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3

# ── Logging level ─────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
